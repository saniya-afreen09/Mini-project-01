#include <wire.h>
#include <LiquidCrystal_I2C.h>
#include <keypad.h>
LiquidCrystal_I2C lcd(0x20,16,2);
//-------keypad setup--------
const byte ROWS = 4;
const byte COLS = 4; 
char keys[ROWS][COLS]={
{'1','2','3','A'},
{'4','5','6','B'},
{'7','8','9','C'},
{'*','0','#','D'}
};
byte rowPins[ROWS] = {9,8,7,6};
byte colPins[COLS] = {5,4,3,2};

Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);

// -------- Variables --------
int totalStudents = 0;
int presentCount = 0;
int entered = 0;

String roll = "";
String studentInput = "";

bool started = false;
bool numberEntered = false;

void setup() {
  lcd.init();
  lcd.backlight();
  lcd.clear();
  lcd.print("Press * to Start");
}

void loop() {

  char key = keypad.getKey();

  if (key) {

    // ---------- STEP 0: WAIT FOR START ----------
    if (!started) {
      if (key == '*') {
        started = true;
        lcd.clear();
        lcd.print("Enter No.Students");
        lcd.setCursor(0,1);
      }
    }
    // ---------- STEP 1: ENTER TOTAL STUDENTS ----------
    else if (!numberEntered) {
      if (key >= '0' && key <= '9') {
        studentInput += key;
        lcd.print(key);
      }

      else if (key == '#') {   // Confirm
        totalStudents = studentInput.toInt();
        numberEntered = true;

        lcd.clear();
        lcd.print("Total: ");
        lcd.print(totalStudents);
        delay(1500);

        lcd.clear();
        lcd.print("Enter Roll No:");
      }

      else if (key == '*') {   // Clear input
        studentInput = "";
        lcd.setCursor(0,1);
        lcd.print("                ");
        lcd.setCursor(0,1);
        }
      }

    // ---------- STEP 2: ATTENDANCE ----------
    else {

      if (key >= '0' && key <= '9') {
        roll += key;
        lcd.setCursor(0,1);
        lcd.print(roll);
      }

      else if (key == 'B') {  // Present
        presentCount++;
        entered++;
        lcd.clear();
        lcd.print("Roll ");
        lcd.print(roll);
        lcd.setCursor(0,1);
        lcd.print("Present");
        delay(1200);
        nextStudent();
      }

      else if (key == 'A') {  // Absent
        entered++;
        lcd.clear();
        lcd.print("Roll ");
        lcd.print(roll);
        lcd.setCursor(0,1);
        lcd.print("Absent");
        delay(1200);
        nextStudent();
      }
      else if (key == 'D') {  // Show Result
        lcd.clear();
        float percentage = ((float)presentCount / totalStudents) * 100;
        lcd.print("Attendance:");
        lcd.setCursor(0,1);
        lcd.print(percentage);
        lcd.print("%");
      }
      else if (key == '*') {  // Clear roll input
        roll = "";
        lcd.setCursor(0,1);
        lcd.print("                ");
        lcd.setCursor(0,1);
      }
    }
  }
}
void nextStudent() {
  roll = "";
  lcd.clear();
  if (entered < totalStudents) {
    lcd.print("Enter Roll No:");
  } else {
    lcd.print("Press D Result");
  }
}







































 
